      },
      "items": [
        {
          "info": {
            "name": "Delete a list of devices within the same application.\nThis operation is atomic; either all devices are deleted or none.\nDevices not found are skipped and no error is returned.",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "{{baseUrl}}/js/applications/:application_ids.application_id/devices/batch",
            "params": [
              {
                "name": "application_ids.application_id",
                "value": "",
                "type": "path"
              },
              {
                "name": "device_ids",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Delete a list of devices within the same application.\nThis operation is atomic; either all devices are deleted or none.\nDevices not found are skipped and no error is returned."
        }
      ]
    },
